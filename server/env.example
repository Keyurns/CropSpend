## Copy to: server/.env

# Server port
PORT=5000

# JWT secret for signing/verifying auth tokens (choose a strong random string)
JWT_SECRET=change_me_to_a_long_random_string

# MongoDB connection string
# Local example:
MONGODB_URI=mongodb://localhost:27017/crospend

# Optional: if your network blocks SRV lookups for Atlas, provide a direct connection string:
# MONGODB_URI_DIRECT=mongodb://USER:PASS@host1:27017,host2:27017,host3:27017/?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin

# Optional email (if you use the email utils)
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password

